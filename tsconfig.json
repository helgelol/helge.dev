{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"$lib/*": ["./src/lib/*"],
			"$assets/*": ["./src/assets/*"]
		}
	},
	"include": ["src/**/*", "index.html"]
}
